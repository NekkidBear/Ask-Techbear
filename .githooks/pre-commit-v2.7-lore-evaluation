#!/bin/bash
# .githooks/pre-commit-v2.6-evaluation-reporting
#
# Enforces v2.6 evaluation, reporting, and persistence constraints.
# Runs alongside v2.0 and v2.5 hooks via pre-commit dispatcher.

echo "🔍 Running TechBear v2.6 evaluation/reporting integrity checks..."

FAIL=0

# =================================================
# 1. No generated report artifacts committed
# =================================================

if find . \
    \( -path "./.git" -o -path "./backend/venv" -o -path "./venv" \) -prune -o \
    \( -name "*.xlsx" -o -name "*.xlsm" -o -name "*.docx" -o -name "*.pdf" \) \
    -print | grep -q .; then
    echo "❌ Generated report/workbook artifacts detected (*.xlsx, *.docx, *.pdf)"
    echo "   Keep generated reports in ignored output folders."
    FAIL=1
fi

# =================================================
# 2. Required generated-output folders must be in .gitignore
# =================================================

for pattern in \
    "reports/" \
    "review_output/" \
    "tests/test_output/" \
    "handoff_output/" \
    "chroma_db/"
do
    if ! grep -qx "$pattern" .gitignore 2>/dev/null; then
        echo "❌ .gitignore missing required generated-output entry: $pattern"
        FAIL=1
    fi
done

# =================================================
# 3. Evaluation schema models must exist once v2.6 implementation begins.
#    Allows early roadmap-only commits; enforces once any evaluation
#    persistence module appears.
# =================================================

if  find backend -type f ! -path "*/venv/*" ! -path "*/__pycache__/*" \
    \( -name "*evaluation*.py" -o -name "*review*.py" -o -name "*report*.py" \) \
    2>/dev/null | grep -q .; then

    if ! grep -R "class PipelineRun" backend 2>/dev/null | grep -q .; then
        echo "❌ Evaluation/reporting code exists, but PipelineRun model was not found"
        FAIL=1
    fi

    if ! grep -R "class LLMScore" backend 2>/dev/null | grep -q .; then
        echo "❌ Evaluation/reporting code exists, but LLMScore model was not found"
        FAIL=1
    fi

    if ! grep -R "class HumanReview" backend 2>/dev/null | grep -q .; then
        echo "❌ Evaluation/reporting code exists, but HumanReview model was not found"
        FAIL=1
    fi
fi

# =================================================
# 4. Pipeline run persistence must not overwrite questions.llm_draft.
#    v2.6 requires multi-run history, not one-question/one-draft.
# =================================================

if grep -R "questions\.llm_draft\|Question\.llm_draft" \
    backend/services/pipeline backend/scripts 2>/dev/null \
    | grep -v "legacy" | grep -q .; then
    echo "❌ Pipeline/evaluation code appears to write directly to questions.llm_draft"
    echo "   v2.6 pipeline outputs should persist through pipeline_runs/artifacts."
    FAIL=1
fi

# =================================================
# 5. Human review data must not be stored only in flat files.
#    Only checks Python source files, not requirements or docs.
#    XLSX is allowed as export/import, not the source of truth.
# =================================================

if grep -Rl "to_excel\|openpyxl\|xlsxwriter" backend \
    --include="*.py" --exclude-dir=venv --exclude-dir=__pycache__ 2>/dev/null | grep -q .; then
    if ! grep -R "class HumanReview\|human_reviews" backend 2>/dev/null | grep -q .; then
        echo "❌ Workbook generation found in Python code, but no human review persistence found"
        echo "   XLSX should be a review export, not the database."
        FAIL=1
    fi
fi

# =================================================
# 6. Lore/fact separation must be preserved.
#    Checks only the RAG module, not comments or utility scripts.
#    Non-blocking warning.
# =================================================

RAG_FILE="backend/services/rag/rag.py"
if [ -f "$RAG_FILE" ]; then
    if grep "def retrieve_facts" "$RAG_FILE" | grep -q "def retrieve_facts"; then
        if ! grep -A5 "def retrieve_facts" "$RAG_FILE" | grep -q "is_fiction"; then
            echo "⚠️  retrieve_facts() in rag.py does not appear to filter by is_fiction."
            echo "   Verify the where clause is present. This warning is non-blocking."
        fi
    fi
fi

# =================================================
# 7. Lore recall must be a distinct benchmark category once added
# =================================================

if grep -R "Captain Janeway\|Delta Quadrant\|Discworld\|Jurassic Park\|Transylvania" \
    tests backend/scripts 2>/dev/null | grep -q .; then
    if ! grep -R "lore\|pass.*[Cc]\|Pass C" tests backend/scripts 2>/dev/null | grep -q .; then
        echo "❌ Lore-related benchmark content found without lore category labeling"
        FAIL=1
    fi
fi

# =================================================
# 8. No local database exports or test result files committed.
#    Excludes known gitignored output directories from the search.
# =================================================

if find . \
    \( -path "./.git" \
       -o -path "./backend/venv" \
       -o -path "./venv" \
       -o -path "./tests/test_output" \
       -o -path "./handoff_output" \) -prune -o \
    \( \
        -name "*questions_export*.csv" \
        -o -name "*pipeline_results*.json" \
        -o -name "*pipeline_test_results*.json" \
    \) \
    -print | grep -q .; then
    echo "❌ Local test/database export detected outside ignored output folders"
    echo "   Keep exports in tests/test_output/ or handoff_output/"
    FAIL=1
fi

# =================================================
# 9. No zip artifacts
# =================================================

if find . -name "*.zip" \
    -not -path "./.git/*" \
    -not -path "./backend/venv/*" \
    -not -path "./venv/*" | grep -q .; then
    echo "❌ zip files detected in repo"
    FAIL=1
fi

# =================================================
# 10. Lore collection must remain isolated from factual critique.
#     Fictional canon must never be passed to the factual critique prompt.
#     NOTE: v2.7 intentionally uses lore chunks in fact_critique.py, but
#     only via the lore critique branch (_build_lore_critique_messages).
#     The check now looks for lore chunks being passed to the FACTUAL
#     critique prompt specifically, not just referenced in the file.
# =================================================

if grep -R "techbear_lore" backend 2>/dev/null | grep -q .; then
    if grep -R "_build_factual_critique_messages" backend 2>/dev/null \
        | grep "lore" \
        | grep -q .; then
        echo "❌ Lore chunks appear to be routed to factual critique prompt"
        echo "   Fictional canon must only be evaluated by lore critique path."
        FAIL=1
    fi
fi

# =================================================
# FINAL DECISION
# =================================================

if [ $FAIL -ne 0 ]; then
    echo ""
    echo "🚨 v2.6 evaluation/reporting integrity check FAILED — commit blocked"
    exit 1
fi

echo "✅ v2.6 evaluation/reporting integrity check passed"
exit 0